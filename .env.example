# Configuration Base de données
DATABASE_URL="postgresql://username:password@localhost:5432/alfred_db?schema=public"

# Configuration JWT
JWT_SECRET="votre-secret-jwt-super-securise-changez-moi"

# Configuration IA - Choisir un provider
# Valeurs possibles: claude, openai, gemini, mistral, ollama
AI_PROVIDER="gemini"

# Clés API des différents providers IA
# ⚠️ Ne committez JAMAIS ces clés dans le code !

# Claude (Anthropic)
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxx"
CLAUDE_MODEL="claude-3-5-sonnet-20241022"

# OpenAI
OPENAI_API_KEY="sk-xxxxxxxxxxxxx"
OPENAI_MODEL="gpt-4-turbo"

# Google Gemini
GEMINI_API_KEY="AIzaSyxxxxxxxxxxxxx"
GEMINI_MODEL="gemini-2.5-flash"

# Mistral AI
MISTRAL_API_KEY="xxxxxxxxxxxxx"
MISTRAL_MODEL="mistral-large-latest"

# Ollama (local - pas besoin d'API key)
OLLAMA_MODEL="llama3.1"

# Configuration Next.js
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Environnement
NODE_ENV="development"
