# Configuration Base de données
# SQLite - base de données locale dans un fichier
DATABASE_URL="file:./prisma/dev.db"

# Configuration JWT
JWT_SECRET=votre-secret-jwt-super-securise-changez-moi

# Configuration IA - Choisir un provider
# Valeurs possibles: claude, openai, gemini, mistral, ollama
AI_PROVIDER="gemini"

# Clés API des différents providers IA
# ⚠️ Ne committez JAMAIS ces clés dans le code !

# Claude (Anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL="claude-3-5-sonnet-20241022"

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL="gpt-4-turbo"

# Google Gemini
GEMINI_API_KEY=votre-clé-ici
GEMINI_MODEL="gemini-2.5-flash"

# Mistral AI
MISTRAL_API_KEY=
MISTRAL_MODEL="mistral-large-latest"

# Ollama (local - pas besoin d'API key)
OLLAMA_MODEL="llama3.1"

# Configuration Next.js
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Environnement
NODE_ENV="development"
